{
  "name": "amrs-preventative-maintenance",
  "version": "1.4.6",
  "description": "Accurate Machine Repair Maintenance Tracker with Offline Sync",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "clean": "rm -rf dist build node_modules/.cache",
    "clean:electron": "rm -rf ~/Library/Application\\ Support/Electron ~/Library/Caches/Electron || true",
    "clean:all": "npm run clean && npm run clean:electron",
    "prepack": "npm run generate:latest",
    "pack": "electron-builder --dir",
    "predist": "npm run generate:latest",
    "dist": "electron-builder",
    "prebuild:win": "npm run generate:latest",
    "build:win": "electron-builder --win",
    "generate:latest": "node generate-latest-yml.js --bundled",
    "generate:package": "node generate-latest-yml.js --copy-package",
    "update:available": "node generate-latest-yml.js --update-available",
    "set:latest": "node generate-latest-yml.js --set-latest --version",
    "auto:version": "node generate-latest-yml.js --update-available",
    "prebuild:win10": "npm run clean && npm run generate:package && npm run generate:latest",
    "postbuild:win10": "npm run auto:version",
    "prebuild:mac": "npm run clean && npm run generate:package && npm run generate:latest",
    "postbuild:mac": "npm run auto:version",
    "prebuild:linux": "npm run clean && npm run generate:package && npm run generate:latest",
    "postbuild:linux": "npm run auto:version",
    "build:win10": "npm run install:electron28 && electron-builder --config electron-builder-win10.js --win",
    "build:mac": "npm run install:electron28 && electron-builder --config electron-builder-macos.js --mac",
    "build:linux": "npm run install:electron28 && electron-builder --config electron-builder-linux.js --linux",
    "build:all": "npm run build:win10 && npm run build:mac && npm run build:linux",
    "install:electron28": "npm install electron@28.3.3",
    "rebuild": "npm run clean:all && npm run build:win10"
  },
  "build": {
    "appId": "com.accuratemachinerepair.maintenancetracker",
    "productName": "Accurate Machine Repair Maintenance Tracker",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://f005.backblazeb2.com/file/amrs-pm-updates/",
        "channel": "latest"
      }
    ],
    "files": [
      "main.js",
      "main-preload.js",
      "splash-preload.js",
      "app/print-preload.js",
      "app/**",
      "assets/**",
      "static/**",
      "templates/**",
      "*.py",
      "models.py",
      "config.py",
      "requirements.txt",
      "package.json",
      "!venv/**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.github/**/*",
      "!**/__pycache__/**/*",
      "!**/*.pyc",
      "!**/*.pyo",
      "!.env",
      "!.env.*",
      "!*.log",
      "!test_*.py",
      "!**/test/**",
      "!**/.DS_Store",
      "!memory-bank/**/*",
      "!docs/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "canvas": "^3.1.0",
    "electron-log": "^5.3.3",
    "electron-updater": "^6.6.2",
    "icon-gen": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drizzydom/AMRS-Preventative-Maintenance.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/drizzydom/AMRS-Preventative-Maintenance/issues"
  },
  "homepage": "https://github.com/drizzydom/AMRS-Preventative-Maintenance#readme"
}
