# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here
FLASK_DEBUG=True
FLASK_PORT=5050

# Application Version (optional - defaults to reading from package.json)
APP_VERSION=1.4.6

# Email configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=maintenance-alerts@yourcompany.com

# Database configuration
DATABASE_URL=postgresql://username:password@hostname/database_name

# Secret key (generate a random one for production)
SECRET_KEY=change_this_to_a_random_secret

# Server configuration
SERVER_NAME=localhost:10000
FLASK_DEBUG=true

# Bootstrap hardening flags (staged rollout)
# Keep defaults for backward compatibility while migrating clients.
ALLOW_LEGACY_BOOTSTRAP_TOKEN=true
ENABLE_DEVICE_BOOTSTRAP_TOKEN=false
BOOTSTRAP_REQUIRE_DEVICE_ID=false
BOOTSTRAP_INCLUDE_ADMIN_SYNC_CREDS=true

# Future device-scoped bootstrap credential (only used when ENABLE_DEVICE_BOOTSTRAP_TOKEN=true)
DEVICE_BOOTSTRAP_TOKEN=

# Optional device identifier header used by bootstrap client requests.
# Recommended when BOOTSTRAP_REQUIRE_DEVICE_ID=true on server.
BOOTSTRAP_DEVICE_ID=

# User-scoped sync token rollout flags
ENABLE_USER_SCOPED_SYNC_TOKEN=false
ALLOW_LEGACY_SYNC_AUTH=true
SYNC_TOKEN_REQUIRE_DEVICE_MATCH=false
SYNC_ACCESS_TOKEN_TTL_SECONDS=43200

# Phase 4 prep: user-scoped sync data filtering (disabled by default)
ENABLE_USER_SCOPED_SYNC_DATA=false
ALLOW_LEGACY_FULL_SYNC_DATA=true
